    // ============================================================
    //  完全體：路亚拟饵推荐 v5.2
    // ============================================================
    function initLureRecommendation() {
        function softcap(x, p) { return x <= 0 ? 0 : x / (x + p); }
        function clamp(x, a, b) { return Math.min(Math.max(x, a), b); }

        const LURE_TO_ACTION = { "水面系": "steady_surface", "亮片": "steady_mid", "摇滚": "steady_mid", "铅头钩": "bottom_hop", "米诺": "mid_twitch" };
        const ACTION_BASE_SPEED = { "steady_surface": 1.55, "steady_mid": 1.20, "bottom_hop": 0.72, "mid_twitch": 1.38 };
        const LURE_TYPE_MODIFIER = { "水面系": 0.15, "亮片": 0.00, "米诺": 0.00, "铅头钩": -0.08, "摇滚": -0.04 };
        const ACTION_NAME = { "steady_surface": "浅层匀速", "steady_mid": "中层匀速", "bottom_hop": "底层跳动", "mid_twitch": "中层抽动" };
        const ACTION_LURE_COMPAT = {
            "steady_surface": { "水面系": 1.0, "亮片": 0.55, "摇滚": 0.50, "铅头钩": 0.30, "米诺": 0.65 },
            "steady_mid":     { "水面系": 0.60, "亮片": 1.0,  "摇滚": 1.0,  "铅头钩": 0.45, "米诺": 0.72 },
            "bottom_hop":     { "水面系": 0.25, "亮片": 0.40, "摇滚": 0.35, "铅头钩": 1.0,  "米诺": 0.42 },
            "mid_twitch":     { "水面系": 0.55, "亮片": 0.68, "摇滚": 0.62, "铅头钩": 0.50, "米诺": 1.0  }
        };
        const WATER_LAYER_NAMES = ["表层", "上层", "中层", "下层", "底层"];
        const ACTION_MAIN_LAYER = { "steady_surface": "表层", "steady_mid": "中层", "bottom_hop": "底层", "mid_twitch": "中层" };

        function calculateRecommendation(preferredLure, agility, alertness, waterLayer) {
            const action = LURE_TO_ACTION[preferredLure] || "mid_twitch";
            const vIdeal = Math.max(0.35, ACTION_BASE_SPEED[action] + (LURE_TYPE_MODIFIER[preferredLure] || 0) + clamp(0.70 * (softcap(agility, 4) - 0.44) - 0.55 * (softcap(alertness, 4) - 0.394), -0.25, 0.25));

            const idx1 = WATER_LAYER_NAMES.indexOf(ACTION_MAIN_LAYER[action] || "中层");
            const idx2 = WATER_LAYER_NAMES.indexOf(waterLayer);
            const rhoLayer = (idx1 === -1 || idx2 === -1) ? 1.0 : (Math.abs(idx1 - idx2) === 0 ? 1.0 : (Math.abs(idx1 - idx2) === 1 ? 0.6 : 0.25));
            const layerDesc = rhoLayer >= 1.0 ? '完全匹配' : (rhoLayer >= 0.6 ? '相邻水层' : '跨层不匹配');

            const rhoAction = (ACTION_LURE_COMPAT[action] || {})[preferredLure] || 0.50;

            return {
                actionName: ACTION_NAME[action],
                median: vIdeal.toFixed(2),
                range: `${Math.max(0.1, vIdeal - 0.25).toFixed(2)} ~ ${(vIdeal + 0.25).toFixed(2)}`,
                rhoLayerDesc: layerDesc,
                rhoAction: (rhoAction * 100).toFixed(0) + '%'
            };
        }

        let currentHash = null;
        let lureTimer = null;
        cleanupTasks.push(() => clearTimeout(lureTimer));

        function runInject() {
            const labels = Array.from(document.querySelectorAll('span.detail-stat-label, .stat-label'));
            const targetLabel = labels.find(s => s.textContent.includes('偏好拟饵'));
            if (!targetLabel) return;

            const container = targetLabel.closest('.detail-stat, .stat-row');
            const valEl = targetLabel.nextElementSibling;
            if (!valEl) return;
            const preferredLure = valEl.textContent.trim();

            const stats = { agility: 5.0, alertness: 4.0, waterLayer: "中层" };
            document.querySelectorAll('.fish-stat-bar-row, .detail-stat, .stat-row').forEach(row => {
                const text = row.textContent || '';
                const vEl = row.querySelector('.fish-stat-bar-value, .detail-stat-value, .stat-value');
                if (!vEl) return;
                const v = parseFloat(vEl.textContent.trim());
                if (text.includes('敏捷') && !isNaN(v)) stats.agility = v;
                if (text.includes('警觉') && !isNaN(v)) stats.alertness = v;
                if (text.includes('水层')) stats.waterLayer = vEl.textContent.trim();
            });

            const rec = calculateRecommendation(preferredLure, stats.agility, stats.alertness, stats.waterLayer);

            if (document.getElementById('lure-rec-block')) document.getElementById('lure-rec-block').remove();
            const div = document.createElement('div');
            div.id = 'lure-rec-block';
            div.style.cssText = 'border-left:4px solid var(--color-primary); margin-top:8px; padding:8px; background:rgba(0,0,0,0.03); font-size:0.9em;';
            div.innerHTML = `
                <div style="font-weight:bold; margin-bottom:4px;">推薦動作: ${rec.actionName}</div>
                <div style="margin-bottom:2px;">水層匹配: ${rec.rhoLayerDesc}</div>
                <div style="margin-bottom:2px;">動作兼容: ${rec.rhoAction}</div>
                <div style="margin-bottom:2px;">中: ${rec.median} m/s  ${rec.range} m/s</div>
            `;
            container.parentNode.insertBefore(div, container.nextSibling);
        }

        const observer = new MutationObserver(() => {
            const labels = Array.from(document.querySelectorAll('span.detail-stat-label, .stat-label'));
            if (labels.some(l => l.textContent.includes('偏好拟饵'))) {
                const nameEl = document.querySelector('.fish-detail-section .detail-title, .modal-title, .fish-name');
                const hash = (nameEl ? nameEl.textContent.trim() : 'Unknown') + "_LURE_V5";
                if (currentHash !== hash) {
                    currentHash = hash;
                    clearTimeout(lureTimer);
                    lureTimer = setTimeout(runInject, 300);
                }
            } else {
                currentHash = null;
            }
        });
        safeObserve(observer, document.body, { childList: true, subtree: true });
    }

