(async function() {
    'use strict';

    // ============================================================
    //  熱更新垃圾回收機制 (Cleanup Tasks)
    // ============================================================
    const cleanupKey = 'LazyFisher_Core_' + Date.now();
    const cleanupTasks = [];
    window.lazyfisherCleanup = window.lazyfisherCleanup || {};
    window.lazyfisherCleanup[cleanupKey] = function() {
        cleanupTasks.forEach(fn => {
            try { fn(); } catch(e) { console.error("Cleanup error:", e); }
        });
    };

    // 註冊安全定時器
    function safeSetInterval(func, time) {
        const id = setInterval(func, time);
        cleanupTasks.push(() => clearInterval(id));
        return id;
    }

    // 註冊安全事件監聽
    function safeAddEventListener(target, event, handler) {
        target.addEventListener(event, handler);
        cleanupTasks.push(() => target.removeEventListener(event, handler));
    }

    // 註冊安全觀察者
    function safeObserve(observer, target, options) {
        observer.observe(target, options);
        cleanupTasks.push(() => observer.disconnect());
    }

    // ============================================================
    //  全域變數與資料核心
    // ============================================================
    let FISH_DATABASE = [];
    let IS_BAIT_MODE = false;
    const JSON_URL = 'https://gist.githubusercontent.com/DelWish-GH/fb39d922fd11ef740e6505e987c8f040/raw/LazyFisher_Fish_DEX.json';

    const BAIT_COLORS = {
        '藻饵': '#2E7D32', '团虫饵': '#4E342E', '虫饵': '#8D6E63', '玉米': '#F9A825',
        '谷物': '#FFB300', '草饵': '#558B2F', '昆虫': '#FF7043', '颗粒': '#5D4037',
        '虾饵': '#E91E63', '螺肉': '#795548', '面饵': '#9C27B0', '活小鱼': '#0288D1',
        '蟹饵': '#D32F2F', '贝类': '#9E9D24', '铅头钩': '#455A64', '亮片': '#FFD700',
        '米诺': '#2E7D32', '摇滚': '#1565C0', '水面系': '#00695C'
    };

    const cleanName = (str) => {
        if (!str) return '';
        return str.replace(/[\u200B-\u200D\uFEFF\u00A0\s]/g, '')
                  .replace(/茲/g, '兹').replace(/魚/g, '鱼').trim();
    };

    async function loadData() {
        try {
            const res = await fetch(JSON_URL + '?t=' + Date.now());
            const data = await res.json();
            FISH_DATABASE = data.content || data || [];
            console.log('✅ 雲端端圖鑑已載入，共', FISH_DATABASE.length, '筆資料');
        } catch (e) { console.log('⚠️ 圖鑑載入失敗', e); }
    }

    // ============================================================
    //  核心功能 A：懸浮按鈕與切換開關
    // ============================================================
    function addFloatingButtons() {
        if (document.getElementById('floating-scroll-btns')) return;
        const div = document.createElement('div');
        div.id = 'floating-scroll-btns';
        div.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 5px;';

        const createBtn = (text, onClick) => {
            const btn = document.createElement('button');
            btn.textContent = text;
            btn.style.cssText = 'padding: 8px 10px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 11px;';
            safeAddEventListener(btn, 'click', onClick);
            return btn;
        };

        div.appendChild(createBtn('↑', () => window.scrollTo({ top: 0, behavior: 'smooth' })));
        div.appendChild(createBtn('↓', () => window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' })));

        const switchBtn = createBtn(IS_BAIT_MODE ? '餌:真' : '餌:擬', () => {
            IS_BAIT_MODE = !IS_BAIT_MODE;
            switchBtn.textContent = IS_BAIT_MODE ? '餌:真' : '餌:擬';
            runLogic();
        });
        div.appendChild(switchBtn);
        document.body.appendChild(div);
        
        cleanupTasks.push(() => {
            const el = document.getElementById('floating-scroll-btns');
            if(el) el.remove();
        });
    }

    // ============================================================
    //  核心功能 B：魚類排續、標籤注入、船釣排序 (極速優化版)
    // ============================================================
    function runLogic() {
        const list = document.querySelector('.card-list');
        if (list) {
            const cards = Array.from(list.querySelectorAll('.card.item-card'));
            const isB = (c) => c.querySelector('button')?.textContent.trim() === '上船' && !c.querySelector('button').disabled;
            cards.sort((a, b) => isB(b) - isB(a));
            cards.forEach(c => list.appendChild(c));
        }

        const grid = document.querySelector('.region-fish-grid');
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.region-fish-card'));

        cards.forEach(card => {
            if (!card.__sortData) {
                const rawName = Array.from(card.querySelector('.item-name')?.childNodes || []).filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim();
                const fishEntry = FISH_DATABASE.find(f => cleanName(f.name) === cleanName(rawName) || cleanName(f["名称"]) === cleanName(rawName));
                const info = fishEntry?.details || fishEntry?.["详情"] || {};

                if (!card.querySelector('.my-tag-container') && fishEntry) {
                    const cont = document.createElement('div');
                    cont.className = 'my-tag-container';
                    cont.style.cssText = 'display:flex; flex-direction:column; align-items:center; margin-top:2px;';

                    if (info['水层']) {
                        const bg = info['水层']==='上层'?'#0D7BC9':info['水层']==='中层'?'#2E7D32':'#D84315';
                        cont.innerHTML += `<div style="background:${bg}; color:white; padding:1px 8px; border-radius:3px; font-size:10px; margin-bottom:2px;">${info['水层']}</div>`;
                    }
                    if (info['偏好拟饵']) cont.innerHTML += `<div style="color:${BAIT_COLORS[info['偏好拟饵']] || '#22B14C'}; font-size:10px; font-weight:bold;">${info['偏好拟饵']}</div>`;
                    if (info['偏好饵料']) cont.innerHTML += `<div style="color:${BAIT_COLORS[info['偏好饵料']] || '#00A2E8'}; font-size:10px; font-weight:bold;">${info['偏好饵料']}</div>`;

                    const ref = card.querySelector('.text-xs.text-muted');
                    if (ref) ref.parentNode.insertBefore(cont, ref);
                }

                let w = 0;
                const weightStr = info['重量'] || info['最大重量'] || info['最小重量'] || '0g';
                const matches = [...weightStr.matchAll(/([\d.]+)\s*(kg|g)/gi)];

                if (matches.length > 0) {
                    const lastMatch = matches[matches.length - 1];
                    w = parseFloat(lastMatch[1]) || 0;
                    if (lastMatch[2].toLowerCase() === 'kg') w *= 1000;
                }

                card.__sortData = {
                    layer: info['水层'] || '', bait: info['偏好饵料'] || '',
                    lure: info['偏好拟饵'] || '', w: w
                };
            }
        });

        cards.sort((a, b) => {
            const lockedA = a.querySelector('.region-fish-lock-button')?.classList.contains('region-fish-lock-button--locked');
            const lockedB = b.querySelector('.region-fish-lock-button')?.classList.contains('region-fish-lock-button--locked');
            if (lockedA && !lockedB) return -1;
            if (!lockedA && lockedB) return 1;

            const dA = a.__sortData || { layer: '', bait: '', lure: '', w: 0 };
            const dB = b.__sortData || { layer: '', bait: '', lure: '', w: 0 };

            const order = { '上层': 1, '中层': 2, '下层': 3 };
            if ((order[dA.layer]||9) !== (order[dB.layer]||9)) return (order[dA.layer]||9) - (order[dB.layer]||9);

            const valA = IS_BAIT_MODE ? dA.bait : dA.lure;
            const valB = IS_BAIT_MODE ? dB.bait : dB.lure;
            if ((valA || '') !== (valB || '')) return (valA || '').localeCompare((valB || ''), 'zh-CN');

            return dB.w - dA.w;
        });

        cards.forEach(c => grid.appendChild(c));
    }

