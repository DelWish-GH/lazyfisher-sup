        async function crawlDex() {
            let fishList = [];
            const cards = document.querySelectorAll('.fish-card');

            const checkStatus = async () => {
                if (isAborted) throw new Error('ABORT');
                while (isPaused) {
                    await new Promise(r => setTimeout(r, 500));
                    if (isAborted) throw new Error('ABORT');
                }
            };

            if (!confirm(`準備採集 ${cards.length} 種魚類...`)) return resetUI();

            try {
                for (let i = 0; i < cards.length; i++) {
                    await checkStatus();
                    statusText.innerText = `📖 圖鑑: ${i+1}/${cards.length}`;

                    cards[i].scrollIntoView({ behavior: 'auto', block: 'center' });
                    cards[i].click();

                    await new Promise(r => setTimeout(r, 600)); 

                    const modal = document.querySelector('.modal-content, .q-dialog');
                    if (modal) {
                        let fishData = {
                            name: modal.querySelector('.modal-title, .text-h6')?.textContent.trim() || '未知',
                            rarity: modal.querySelector('.inline-meta')?.textContent.trim() || '未知',
                            scientific_name: modal.querySelector('.text-sm.text-muted')?.textContent.trim() || '',
                            stats: {},
                            details: {}
                        };

                        modal.querySelectorAll('.fish-stat-bar-row, .row').forEach(row => {
                            let label = row.querySelector('.fish-stat-bar-label, .text-left')?.textContent.trim();
                            let val = row.querySelector('.fish-stat-bar-value, .text-right')?.textContent.trim();
                            if (label && val) {
                                fishData.stats[label] = val;
                            }
                        });

                        modal.querySelectorAll('.detail-stat, .q-item').forEach(stat => {
                            let label = stat.querySelector('.detail-stat-label, .q-item__label--caption')?.textContent.trim();
                            let val = stat.querySelector('.detail-stat-value, .q-item__label--body, .text-right')?.textContent.trim();

                            if (label) label = label.replace(/[:：]$/, '').trim();

                            if (label && val) {
                                fishData.details[label] = val;
                            }
                        });

                        fishList.push(fishData);
                    }

                    const closeBtn = document.querySelector('.modal-close, .q-btn.close-btn');
                    if (closeBtn) closeBtn.click();

                    await new Promise(r => setTimeout(r, 200));
                }

                download({ page: '魚類圖鑑', content: fishList }, 'dex');
            } catch (e) {
                if (e.message === 'ABORT') {
                    console.log('🛑 圖鑑採集已中止');
                    statusText.innerText = '🛑 已中止';
                    if (fishList.length > 0) download({ page: '魚類圖鑑_未完成', content: fishList }, 'dex_partial');
                } else {
                    console.error("圖鑑採集錯誤:", e);
                    statusText.innerText = '❌ 發生錯誤';
                }
            }

            resetUI();
        }

        function parseHelpContent(container) {
            let sections = [];
            let currentSection = { title: '前言/概述', content: [] };

            Array.from(container.children).forEach(node => {
                if (/^H[1-6]$/.test(node.tagName)) {
                    if (currentSection.content.length > 0 || currentSection.title !== '前言/概述') {
                        sections.push(currentSection);
                    }
                    currentSection = { title: node.innerText.trim(), content: [] };
                }
                else if ((node.tagName === 'DIV' && node.classList.contains('help-table-wrap')) || node.tagName === 'TABLE') {
                    let tableNode = node.tagName === 'TABLE' ? node : node.querySelector('table');
                    if (tableNode) {
                        let tableData = [];
                        let headers = Array.from(tableNode.querySelectorAll('th')).map(th => extractTextOrLatex(th));
                        if(headers.length > 0) tableData.push(headers);

                        let rows = tableNode.querySelectorAll('tbody tr');
                        rows.forEach(tr => {
                            let rowData = Array.from(tr.querySelectorAll('td')).map(td => extractTextOrLatex(td));
                            tableData.push(rowData);
                        });
                        currentSection.content.push({ type: 'table', data: tableData });
                    }
                }
                else if (node.classList && node.classList.contains('katex-display')) {
                    let annotation = node.querySelector('annotation[encoding="application/x-tex"]');
                    if (annotation && annotation.textContent) {
                        currentSection.content.push(`$$ ${annotation.textContent.trim()} $$`);
                    }
                }
                else if (['P', 'UL', 'OL', 'PRE', 'CODE'].includes(node.tagName)) {
                    if (node.classList.contains('help-formula-section-picker') || node.classList.contains('help-document-picker')) return;
                    let text = extractTextOrLatex(node);
                    if (text) currentSection.content.push(text);
                }
            });

            if (currentSection.content.length > 0) sections.push(currentSection);
            return sections;
        }

        function extractTextOrLatex(node) {
            let result = "";
            node.childNodes.forEach(child => {
                if (child.nodeType === Node.TEXT_NODE) {
                    result += child.textContent;
                } else if (child.nodeType === Node.ELEMENT_NODE) {
                    if (child.classList.contains('katex')) {
                        let annotation = child.querySelector('annotation[encoding="application/x-tex"]');
                        if (annotation && annotation.textContent) {
                            result += `$${annotation.textContent.trim()}$`;
                        } else {
                            result += child.textContent || "";
                        }
                    } else {
                        result += extractTextOrLatex(child);
                    }
                }
            });
            return result.trim().replace(/\s+/g, ' ');
        }

        function download(data, name) {
            if (!data.content || data.content.length === 0) return;
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            const timestamp = new Date().toISOString().replace(/[:T]/g, '-').slice(0,19);
            a.download = `LazyFisher_${name}_${timestamp}.json`;
            a.click();
        }

        function resetUI() {
            startBtn.style.display = 'block'; pauseBtn.style.display = 'none'; abortBtn.style.display = 'none';
            pauseBtn.innerText = '⏸️ 暫停';
            refreshUI();
        }

        refreshUI();
    }

    // ============================================================
    //  主程式執行入口
    // ============================================================
    async function boot() {
        console.log('🚀 開始初始化 LazyFisher 核心 Payload...');

        await loadData();

        addFloatingButtons();
        safeSetInterval(runLogic, 2000); 

        initSmartContrastCurrency();
        initLureSoftnessModule();
        initLogColorer();
        initCatchTimer();
        initReelEnhancer();
        initLureRecommendation();
        initCastOffsetDisplay();
        initLureActionSpeedHelper();
        initCompactRegionCards();
        
        // 🌟 新增：數據採集器 (內含行動裝置偵測)
        initDataCrawler();

        console.log('✨ LazyFisher Payload 啟動完畢！熱更新就緒。');
    }

    if (document.readyState === 'loading') {
        const bootHandler = () => boot();
        document.addEventListener('DOMContentLoaded', bootHandler);
        cleanupTasks.push(() => document.removeEventListener('DOMContentLoaded', bootHandler));
    } else {
        boot();
    }

})();
