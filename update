    // ============================================================
    //  完全體：路亚拟饵推荐 v5.2
    // ============================================================
    function initLureRecommendation() {
        function softcap(x, p) { return x <= 0 ? 0 : x / (x + p); }
        function clamp(x, a, b) { return Math.min(Math.max(x, a), b); }

        const LURE_TO_ACTION = { "水面系": "steady_surface", "亮片": "steady_mid", "摇滚": "steady_mid", "铅头钩": "bottom_hop", "米诺": "mid_twitch" };
        const ACTION_BASE_SPEED = { "steady_surface": 1.55, "steady_mid": 1.20, "bottom_hop": 0.72, "mid_twitch": 1.38 };
        const LURE_TYPE_MODIFIER = { "水面系": 0.15, "亮片": 0.00, "米诺": 0.00, "铅头钩": -0.08, "摇滚": -0.04 };
        const ACTION_NAME = { "steady_surface": "浅层匀速", "steady_mid": "中层匀速", "bottom_hop": "底层跳动", "mid_twitch": "中层抽动" };
        const ACTION_LURE_COMPAT = {
            "steady_surface": { "水面系": 1.0, "亮片": 0.55, "摇滚": 0.50, "铅头钩": 0.30, "米诺": 0.65 },
            "steady_mid":     { "水面系": 0.60, "亮片": 1.0,  "摇滚": 1.0,  "铅头钩": 0.45, "米诺": 0.72 },
            "bottom_hop":     { "水面系": 0.25, "亮片": 0.40, "摇滚": 0.35, "铅头钩": 1.0,  "米诺": 0.42 },
            "mid_twitch":     { "水面系": 0.55, "亮片": 0.68, "摇滚": 0.62, "铅头钩": 0.50, "米诺": 1.0  }
        };
        const WATER_LAYER_NAMES = ["表层", "上层", "中层", "下层", "底层"];
        const ACTION_MAIN_LAYER = { "steady_surface": "表层", "steady_mid": "中层", "bottom_hop": "底层", "mid_twitch": "中层" };

        function calculateRecommendation(preferredLure, agility, alertness, waterLayer) {
            const action = LURE_TO_ACTION[preferredLure] || "mid_twitch";
            const vIdeal = Math.max(0.35, ACTION_BASE_SPEED[action] + (LURE_TYPE_MODIFIER[preferredLure] || 0) + clamp(0.70 * (softcap(agility, 4) - 0.44) - 0.55 * (softcap(alertness, 4) - 0.394), -0.25, 0.25));

            const idx1 = WATER_LAYER_NAMES.indexOf(ACTION_MAIN_LAYER[action] || "中层");
            const idx2 = WATER_LAYER_NAMES.indexOf(waterLayer);
            const rhoLayer = (idx1 === -1 || idx2 === -1) ? 1.0 : (Math.abs(idx1 - idx2) === 0 ? 1.0 : (Math.abs(idx1 - idx2) === 1 ? 0.6 : 0.25));
            const layerDesc = rhoLayer >= 1.0 ? '完全匹配' : (rhoLayer >= 0.6 ? '相邻水层' : '跨层不匹配');

            const rhoAction = (ACTION_LURE_COMPAT[action] || {})[preferredLure] || 0.50;

            return {
                actionName: ACTION_NAME[action],
                median: vIdeal.toFixed(2),
                range: `${Math.max(0.1, vIdeal - 0.25).toFixed(2)} ~ ${(vIdeal + 0.25).toFixed(2)}`,
                rhoLayerDesc: layerDesc,
                rhoAction: (rhoAction * 100).toFixed(0) + '%'
            };
        }

        let currentHash = null;
        let lureTimer = null;
        cleanupTasks.push(() => clearTimeout(lureTimer));

        function runInject() {
            const labels = Array.from(document.querySelectorAll('span.detail-stat-label, .stat-label'));
            const targetLabel = labels.find(s => s.textContent.includes('偏好拟饵'));
            if (!targetLabel) return;

            const container = targetLabel.closest('.detail-stat, .stat-row');
            const valEl = targetLabel.nextElementSibling;
            if (!valEl) return;
            const preferredLure = valEl.textContent.trim();

            const stats = { agility: 5.0, alertness: 4.0, waterLayer: "中层" };
            document.querySelectorAll('.fish-stat-bar-row, .detail-stat, .stat-row').forEach(row => {
                const text = row.textContent || '';
                const vEl = row.querySelector('.fish-stat-bar-value, .detail-stat-value, .stat-value');
                if (!vEl) return;
                const v = parseFloat(vEl.textContent.trim());
                if (text.includes('敏捷') && !isNaN(v)) stats.agility = v;
                if (text.includes('警觉') && !isNaN(v)) stats.alertness = v;
                if (text.includes('水层')) stats.waterLayer = vEl.textContent.trim();
            });

            const rec = calculateRecommendation(preferredLure, stats.agility, stats.alertness, stats.waterLayer);

            if (document.getElementById('lure-rec-block')) document.getElementById('lure-rec-block').remove();
            const div = document.createElement('div');
            div.id = 'lure-rec-block';
            div.style.cssText = 'border-left:4px solid var(--color-primary); margin-top:8px; padding:8px; background:rgba(0,0,0,0.03); font-size:0.9em;';
            div.innerHTML = `
                <div style="font-weight:bold; margin-bottom:4px;">推薦動作: ${rec.actionName}</div>
                <div style="margin-bottom:2px;">水層匹配: ${rec.rhoLayerDesc}</div>
                <div style="margin-bottom:2px;">動作兼容: ${rec.rhoAction}</div>
                <div style="margin-bottom:2px;">中: ${rec.median} m/s  ${rec.range} m/s</div>
            `;
            container.parentNode.insertBefore(div, container.nextSibling);
        }

        const observer = new MutationObserver(() => {
            const labels = Array.from(document.querySelectorAll('span.detail-stat-label, .stat-label'));
            if (labels.some(l => l.textContent.includes('偏好拟饵'))) {
                const nameEl = document.querySelector('.fish-detail-section .detail-title, .modal-title, .fish-name');
                const hash = (nameEl ? nameEl.textContent.trim() : 'Unknown') + "_LURE_V5";
                if (currentHash !== hash) {
                    currentHash = hash;
                    clearTimeout(lureTimer);
                    lureTimer = setTimeout(runInject, 300);
                }
            } else {
                currentHash = null;
            }
        });
        safeObserve(observer, document.body, { childList: true, subtree: true });
    }

    // ============================================================
    //  增強模組 8：數據採集器 (僅電腦端啟動)
    // ============================================================
    function initDataCrawler() {
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 800;
        if (isMobile) {
            console.log('📱 偵測為行動裝置，數據採集器已停用。');
            return;
        }

        console.log('💻 偵測為桌面裝置，啟動數據採集器模組。');

        let isPaused = false;
        let isAborted = false;

        const routeMap = {
            'fishing': '🎣 釣魚介面', 'keep': '🐟 魚獲管理', 'region': '🗺️ 釣場資訊',
            'equipment': '⚔️ 裝備配置', 'inventory': '🎒 背包物品', 'shop': '💰 商店裝備',
            'messages': '💬 系統消息', 'guild': '🏛️ 協會任務', 'dex': '📖 魚類圖鑑',
            'achievements': '🏆 成就系統', 'rankings': '📊 排行榜', 'profile': '👤 個人檔案', 'help': '❓ 幫助說明'
        };

        const panel = document.createElement('div');
        panel.id = 'lazyfisher-crawler-panel';
        panel.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;background:rgba(0,0,0,0.85);padding:15px;border-radius:15px;box-shadow:0 4px 15px rgba(0,0,0,0.5);width:170px;border:1px solid #444;';
        document.body.appendChild(panel);
        cleanupTasks.push(() => {
            const el = document.getElementById('lazyfisher-crawler-panel');
            if(el) el.remove();
        });

        const statusText = document.createElement('div');
        statusText.style.cssText = 'color:#4caf50;font-size:12px;font-weight:bold;margin-bottom:5px;text-align:center;';
        statusText.innerText = '📡 待機中';
        panel.appendChild(statusText);

        function createBtn(text, color, onClick) {
            const b = document.createElement('button');
            b.innerText = text;
            b.style.cssText = `padding:10px;background:${color};color:white;border:none;border-radius:8px;cursor:pointer;font-weight:bold;font-size:12px;`;
            safeAddEventListener(b, 'click', onClick);
            panel.appendChild(b);
            return b;
        }

        const startBtn = createBtn('🚀 開始採集', '#4caf50', () => handleAction('start'));
        const pauseBtn = createBtn('⏸️ 暫停', '#ff9800', () => handleAction('pause'));
        const abortBtn = createBtn('🛑 中止並導出', '#f44336', () => handleAction('abort'));
        pauseBtn.style.display = 'none';
        abortBtn.style.display = 'none';

        function getActiveRoute() {
            const path = window.location.hash || window.location.pathname;
            for (let key in routeMap) { if (path.includes(key)) return { key, name: routeMap[key] }; }
            return { key: 'unknown', name: '未知區域' };
        }

        function refreshUI() {
            const route = getActiveRoute();
            startBtn.innerText = `🚀 採集 ${route.name}`;
            startBtn.style.display = (route.key === 'unknown' || pauseBtn.style.display === 'block') ? 'none' : 'block';
        }

        const hashHandler = () => refreshUI();
        safeAddEventListener(window, 'hashchange', hashHandler);
        safeAddEventListener(window, 'popstate', hashHandler);
        
        const originalPushState = history.pushState;
        history.pushState = function() { originalPushState.apply(this, arguments); refreshUI(); };
        cleanupTasks.push(() => { history.pushState = originalPushState; });

        async function handleAction(type) {
            const route = getActiveRoute();
            if (type === 'start') {
                isAborted = false; isPaused = false;
                startBtn.style.display = 'none'; pauseBtn.style.display = 'block'; abortBtn.style.display = 'block';
                await runCrawl(route);
            } else if (type === 'pause') {
                isPaused = !isPaused;
                pauseBtn.innerText = isPaused ? '▶️ 繼續' : '⏸️ 暫停';
                statusText.innerText = isPaused ? '⏸️ 已暫停' : '📡 執行中...';
            } else if (type === 'abort') {
                isAborted = true;
                statusText.innerText = '🛑 正在中止...';
            }
        }

        async function runCrawl(route) {
            let results = [];
            let data = { page: route.name, url: window.location.href, timestamp: new Date().toLocaleString(), content: null };

            const checkStatus = async () => {
                if (isAborted) throw new Error('ABORT');
                while (isPaused) {
                    await new Promise(r => setTimeout(r, 500));
                    if (isAborted) throw new Error('ABORT');
                }
            };

            try {
                switch (route.key) {
                    case 'fishing':
                        data.content = {
                            daily_target: {
                                fish: document.querySelector('.card strong:nth-child(1)')?.innerText,
                                location: document.querySelector('.card .inline-meta:nth-child(2)')?.innerText,
                                status: document.querySelector('.card .text-success')?.innerText || '未完成'
                            },
                            current_status: {
                                area: document.querySelector('.fishing-overview-item:nth-child(1) strong')?.innerText,
                                spot: document.querySelector('.fishing-overview-item:nth-child(2) strong')?.innerText,
                                keep_limit: document.querySelector('.fishing-overview-item:nth-child(3) strong')?.innerText,
                                game_time: document.querySelector('.fishing-overview-item:nth-child(4) strong')?.innerText
                            },
                            environment: {
                                wind: document.querySelector('span[title^="风"]')?.innerText,
                                cloud: document.querySelector('span[title^="云"]')?.innerText,
                                rain: document.querySelector('span[title^="雨"]')?.innerText
                            },
                            last_catch: document.querySelector('.alert-success .text-sm')?.innerText
                        };
                        break;

                    case 'keep':
                        const fishCards = document.querySelectorAll('.item-card');
                        for (let i = 0; i < fishCards.length; i++) {
                            await checkStatus();
                            statusText.innerText = `🔄 進度: ${i + 1}/${fishCards.length}`;
                            let card = fishCards[i];
                            card.scrollIntoView({ behavior: 'auto', block: 'center' });
                            card.click();
                            await new Promise(r => setTimeout(r, 600));
                            const modal = document.querySelector('.modal-content');
                            if (modal) {
                                const getByLabel = (label) => {
                                    const stats = Array.from(modal.querySelectorAll('.detail-stat'));
                                    const target = stats.find(s => s.querySelector('.detail-stat-label')?.innerText.includes(label));
                                    return target ? target.querySelector('.detail-stat-value')?.innerText.trim() : '未知';
                                };
                                results.push({
                                    name: modal.querySelector('.modal-title')?.innerText,
                                    rating: getByLabel('评级'), score: getByLabel('评分'),
                                    size: getByLabel('体长'), weight: getByLabel('重量'),
                                    location: getByLabel('钓获位置'), time: getByLabel('钓获时间'),
                                    params: getByLabel('作钓参数'),
                                    sell_price: modal.querySelector('.currency-item[title="金钱"]')?.innerText.trim() || getByLabel('售出价值'),
                                    release_exp: getByLabel('放生收益')
                                });
                            }
                            document.querySelector('.modal-close')?.click();
                            await new Promise(r => setTimeout(r, 300));
                        }
                        data.content = results;
                        break;

                    case 'equipment':
                        let activeEquip = {
                            loadout_name: document.querySelector('.equipment-loadout-tab.tab-active')?.innerText.trim(),
                            tension_summary: document.querySelector('.equipment-tension-summary')?.innerText.replace(/\n/g, ' | '),
                            controls: document.querySelector('.loadout-control-summary')?.innerText,
                            summary_stats: {},
                            import_export_config: null,
                            details: []
                        };

                        const summaryBlocks = document.querySelectorAll('.equipment-selection-summary-block');
                        summaryBlocks.forEach(block => {
                            const label = block.querySelector('.text-sm.text-muted')?.innerText.trim();
                            const val = block.querySelector('.equipment-selection-summary-value')?.innerText.trim();
                            if (label && val) {
                                activeEquip.summary_stats[label] = val;
                            }
                        });

                        const importExportBtn = Array.from(document.querySelectorAll('.page-wrapper button, .main-content button'))
                                                     .find(b => b.innerText.includes('导入导出'));
                        if (importExportBtn) {
                            importExportBtn.click();
                            await new Promise(r => setTimeout(r, 600)); 

                            const modalTextarea = document.querySelector('.modal-content textarea, .q-dialog textarea, textarea');
                            if (modalTextarea && modalTextarea.value) {
                                try {
                                    activeEquip.import_export_config = JSON.parse(modalTextarea.value);
                                } catch (e) {
                                    activeEquip.import_export_config = modalTextarea.value.trim();
                                }
                            }

                            const closeBtn = document.querySelector('.modal-close, .q-btn.close-btn') || document.querySelector('.q-dialog__backdrop');
                            if (closeBtn) closeBtn.click();
                            await new Promise(r => setTimeout(r, 300));
                        }

                        const activeSlots = document.querySelectorAll('.loadout-slot');
                        for (let slot of activeSlots) {
                            await checkStatus();
                            const label = slot.querySelector('.loadout-slot-label')?.innerText;
                            const slotName = slot.querySelector('.loadout-slot-name')?.innerText;
                            const detailBtn = slot.querySelector('.loadout-slot-action');
