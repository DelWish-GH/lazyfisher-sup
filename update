                        if(invCards.length === 0) { statusText.innerText = "❌ 找不到物品"; break; }

                        for (let i = 0; i < invCards.length; i++) {
                            await checkStatus();
                            let card = invCards[i];
                            let cardText = card.innerText || "";
                            if (cardText.includes('服饰') || cardText.includes('家具')) {
                                console.log(`⏩ 跳過背包非必要物品:`, cardText.split('\n')[0]);
                                continue;
                            }

                            statusText.innerText = `🎒 進度: ${i+1}/${invCards.length}`;
